{
  "name": "prison-sis-tauri",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "ppt:install-browsers": "export PLAYWRIGHT_BROWSERS_PATH=\"$PWD/.pw-browsers\" && npx playwright install chromium",
    "ppt:screenshots": "export PLAYWRIGHT_BROWSERS_PATH=\"$PWD/.pw-browsers\" && npx playwright test e2e/ppt-screenshots.spec.ts",
    "ppt:report": "export PLAYWRIGHT_BROWSERS_PATH=\"$PWD/.pw-browsers\" && npx playwright test e2e/ppt-screenshots.spec.ts && cd .. && python3 generate_prisonsis_ppt_report_with_images.py"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
